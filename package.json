{
  "name": "signal-coach-core",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:clean": "pkill -f wrangler || true && pkill -f vite || true",
    "dev:host": "vite --host 0.0.0.0 --port 5173",
    "tunnel": "cloudflared tunnel --url http://localhost:5173",
    "prebuild": "npm run check:rps-ux-guardrails",
    "build": "vite build",
    "ci:build": "npm run build",
    "check:rps-ux-guardrails": "node scripts/check-rps-ux-guardrails.mjs",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p ./jsconfig.json",
    "audit:openers": "npx vite-node scripts/audit-opening-realism.ts",
    "audit:scenarios": "npx vite-node scripts/audit-scenarios.ts",
    "audit:architecture": "npx vite-node scripts/audit-architecture-alignment.ts",
    "qa:matrix": "npx vite-node scripts/qa-matrix.ts",
    "confidence:gate": "VITE_ROLEPLAY_WORKER_URL=${VITE_ROLEPLAY_WORKER_URL:-https://reflectivai-rps-api-staging.tonyabdelmalak.workers.dev} npx vite-node scripts/confidence-gate.ts",
    "test:adaptive-temperature": "npx vite-node scripts/adaptive-temperature-tests.ts",
    "test:adaptive-calibration": "npx vite-node scripts/adaptive-realism-calibration-tests.ts",
    "test:scenario-routing-guardrails": "npx vite-node scripts/scenario-routing-guardrails.ts",
    "test:qa-realism-calibration": "npx vite-node scripts/qa-realism-calibration.ts",
    "test:runtime-alignment": "node scripts/runtime-alignment-check.js",
    "test:hcp-brain-rps": "npx vite-node scripts/test-hcp-brain-rps.ts",
    "test:voice-adaptation": "npx vite-node scripts/voice-adaptation-tests.ts",
    "test:rps-regression": "npx vite-node scripts/rps-staging-regression.ts",
    "test:cross-path-parity": "VITE_ROLEPLAY_WORKER_URL=${VITE_ROLEPLAY_WORKER_URL:-https://reflectivai-rps-api-staging.tonyabdelmalak.workers.dev} npx vite-node scripts/cross-path-parity-gate.ts",
    "test:persona-lane-calibration": "VITE_ROLEPLAY_WORKER_URL=${VITE_ROLEPLAY_WORKER_URL:-https://reflectivai-rps-api-staging.tonyabdelmalak.workers.dev} npx vite-node scripts/persona-lane-calibration.ts",
    "test:continuous-learning-eval": "npx vite-node scripts/continuous-learning-memory-eval.ts",
    "continuous-learning:promote": "npx vite-node scripts/continuous-learning-memory-eval.ts --promote",
    "test:release-candidate-gates": "npm run confidence:gate && npm run test:opener-adaptation && npm run test:cross-path-parity && npm run test:persona-lane-calibration && npm run test:continuous-learning-eval",
    "test:opener-adaptation": "VITE_ROLEPLAY_WORKER_URL=${VITE_ROLEPLAY_WORKER_URL:-https://reflectivai-rps-api-staging.tonyabdelmalak.workers.dev} npx vite-node scripts/rps-opener-adaptation-sweep.ts",
    "test:hcp-state-progression": "node scripts/hcp-state-progression-validation.mjs",
    "test:response-type-diversity": "node scripts/response-type-diversity-check.mjs",
    "predeploy": "npm run check:rps-ux-guardrails && npm run test:opener-adaptation && npm run predeploy-verify",
    "predeploy-verify": "npx vite-node scripts/predeploy-verify.ts",
    "preview": "vite preview",
    "worker:dev": "wrangler dev --config wrangler.toml --port 8787",
    "dev:worker": "wrangler dev --config wrangler.toml --port 8787",
    "worker:deploy": "node scripts/protected-rps-target-guard.js worker:deploy && wrangler deploy --config wrangler.toml",
    "prefrontend:deploy": "npm run check:rps-ux-guardrails",
    "frontend:deploy": "node scripts/protected-rps-target-guard.js frontend:deploy && wrangler pages deploy dist --project-name signal-coach-roleplay-simulator --commit-dirty=true",
    "frontend:deploy:staging:verified": "bash scripts/deploy-staging-verified.sh",
    "deploy:full": "node scripts/protected-rps-target-guard.js deploy:full && node scripts/deploy-guard.js && npm run build && npm run worker:deploy && npm run frontend:deploy"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^17.0.0",
    "@hookform/resolvers": "^4.1.2",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-aspect-ratio": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-context-menu": "^2.2.6",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-hover-card": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-navigation-menu": "^1.2.5",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-toggle": "^1.1.2",
    "@radix-ui/react-toggle-group": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@stripe/react-stripe-js": "^3.0.0",
    "@stripe/stripe-js": "^5.2.0",
    "@tanstack/react-query": "^5.84.1",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.5.2",
    "framer-motion": "^11.16.4",
    "html2canvas": "^1.4.1",
    "input-otp": "^1.4.2",
    "jspdf": "^4.0.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.475.0",
    "moment": "^2.30.1",
    "next-themes": "^0.4.4",
    "react": "^18.2.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.54.2",
    "react-hot-toast": "^2.6.0",
    "react-leaflet": "^4.2.1",
    "react-markdown": "^9.0.1",
    "react-quill": "^2.0.0",
    "react-resizable-panels": "^2.1.7",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.15.4",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.171.0",
    "vaul": "^1.1.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/node": "^22.13.5",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "baseline-browser-mapping": "^2.8.32",
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^15.14.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^6.1.0",
    "wrangler": "^4.12.0"
  }
}
