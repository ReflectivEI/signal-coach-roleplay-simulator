{
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "esnext",
      "dom"
    ],
    "target": "esnext",
    "checkJs": true,
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 0,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/App.jsx",
    "src/main.jsx",
    "src/lib/**/*",
    "src/services/**/*",
    "src/pages/**/*",
    "src/components/home/**/*",
    "src/components/simulator/**/*",
    "src/components/layout/**/*",
    "scripts/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/vite-plugins",
    "src/components/ui/**/*"
  ]
}